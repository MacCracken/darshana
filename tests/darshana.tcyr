# darshana test suite — exercises the pure-function pieces of the M1
# donor port. The TTY-bound functions (tty_raw / tty_cooked / tty_*)
# need a real TTY fd to ioctl against and a way to capture stdout
# bytes — neither is available cleanly in unit-test scope. The
# pre-existing cyim PTY integration smoke covers them end-to-end;
# darshana's CI re-runs cyim's smoke at Phase 4 of the migration plan.
#
# Stdlib auto-included via cyrius.cyml; src/main.cyr pulls in the
# three domain modules.

include "src/main.cyr"

fn main() {
    alloc_init();

    test_group("smoke");
    assert(1, "true is true");
    assert_eq(1 + 1, 2, "math works");

    # ----- termios.cyr — 32-bit LE field accessors -----------------
    # Pure functions over a stack buffer; no TTY involvement.

    test_group("termios.cyr — tio_load32 / tio_store32 round-trip");
    var fbuf[16];
    var i = 0;
    while (i < 16) { store8(&fbuf + i, 0); i = i + 1; }
    tio_store32(&fbuf, 0, 0x12345678);
    assert_eq(load8(&fbuf + 0), 0x78, "byte 0 little-endian");
    assert_eq(load8(&fbuf + 1), 0x56, "byte 1 little-endian");
    assert_eq(load8(&fbuf + 2), 0x34, "byte 2 little-endian");
    assert_eq(load8(&fbuf + 3), 0x12, "byte 3 little-endian");
    assert_eq(tio_load32(&fbuf, 0), 0x12345678, "load32 round-trip");
    # Offset != 0
    tio_store32(&fbuf, 4, 0xDEADBEEF);
    assert_eq(tio_load32(&fbuf, 4), 0xDEADBEEF, "load32 at offset 4");
    # Adjacent fields don't bleed
    assert_eq(tio_load32(&fbuf, 0), 0x12345678, "field at 0 untouched by write at 4");

    # ----- termios.cyr — tty_apply_raw_flags ----------------------
    # Set up a faked cooked-mode termios with all flags ON, then apply
    # the raw mask and verify the right bits cleared / set. Mirrors
    # cyim's vim-convention raw mode: ISIG cleared (Ctrl-C as byte),
    # OPOST cleared, etc. Same bit checks as the donor's intent.

    test_group("termios.cyr — tty_apply_raw_flags");
    var tbuf[60];
    var j = 0;
    while (j < 60) { store8(&tbuf + j, 0); j = j + 1; }
    # Pre-load all c_iflag/oflag/lflag bits we expect to clear.
    tio_store32(&tbuf, 0,
        TIO_BRKINT | TIO_ICRNL | TIO_INPCK | TIO_ISTRIP | TIO_IXON);
    tio_store32(&tbuf, 4, TIO_OPOST);
    # c_cflag — pre-load with junk in CSIZE bits to verify they get cleared+CS8 set.
    tio_store32(&tbuf, 8, 0xFF);
    tio_store32(&tbuf, 12,
        TIO_ECHO | TIO_ICANON | TIO_IEXTEN | TIO_ISIG);
    # Junk in c_cc[VMIN] / c_cc[VTIME] to verify they get overwritten.
    store8(&tbuf + TIO_CC_BASE + TIO_VMIN, 99);
    store8(&tbuf + TIO_CC_BASE + TIO_VTIME, 99);

    tty_apply_raw_flags(&tbuf);

    # iflag — every set bit cleared.
    assert_eq(tio_load32(&tbuf, 0) & TIO_BRKINT, 0, "BRKINT cleared");
    assert_eq(tio_load32(&tbuf, 0) & TIO_ICRNL,  0, "ICRNL cleared");
    assert_eq(tio_load32(&tbuf, 0) & TIO_INPCK,  0, "INPCK cleared");
    assert_eq(tio_load32(&tbuf, 0) & TIO_ISTRIP, 0, "ISTRIP cleared");
    assert_eq(tio_load32(&tbuf, 0) & TIO_IXON,   0, "IXON cleared");
    # oflag — OPOST cleared.
    assert_eq(tio_load32(&tbuf, 4) & TIO_OPOST, 0, "OPOST cleared");
    # cflag — CSIZE cleared, CS8 set.
    assert_eq(tio_load32(&tbuf, 8) & TIO_CS8, TIO_CS8, "CS8 set");
    # lflag — every set bit cleared.
    assert_eq(tio_load32(&tbuf, 12) & TIO_ECHO,   0, "ECHO cleared");
    assert_eq(tio_load32(&tbuf, 12) & TIO_ICANON, 0, "ICANON cleared");
    assert_eq(tio_load32(&tbuf, 12) & TIO_IEXTEN, 0, "IEXTEN cleared");
    assert_eq(tio_load32(&tbuf, 12) & TIO_ISIG,   0, "ISIG cleared (Ctrl-C as byte)");
    # c_cc.
    assert_eq(load8(&tbuf + TIO_CC_BASE + TIO_VMIN),  1, "VMIN = 1 (read returns on 1 byte)");
    assert_eq(load8(&tbuf + TIO_CC_BASE + TIO_VTIME), 0, "VTIME = 0 (no read timeout)");

    # Idempotence — re-applying the mask shouldn't change anything.
    var snap[60];
    var k = 0;
    while (k < 60) { store8(&snap + k, load8(&tbuf + k)); k = k + 1; }
    tty_apply_raw_flags(&tbuf);
    var match_n = 0;
    var p = 0;
    while (p < 60) {
        if (load8(&tbuf + p) == load8(&snap + p)) { match_n = match_n + 1; }
        p = p + 1;
    }
    assert_eq(match_n, 60, "tty_apply_raw_flags is idempotent");

    # ----- cursor.cyr — tty_itoa decimal formatter ----------------
    # Test the full range cyim uses (1..200 covers any terminal of
    # reasonable size; the tested values straddle the digit boundaries).

    test_group("cursor.cyr — tty_itoa");
    var ibuf[24];
    # Zero
    var z = 0;
    while (z < 24) { store8(&ibuf + z, 0); z = z + 1; }
    assert_eq(tty_itoa(&ibuf, 0, 0), 1, "0 → 1 digit");
    assert_eq(load8(&ibuf), 0x30, "0 written as ASCII '0'");
    # Negative — donor treats <= 0 as 0
    assert_eq(tty_itoa(&ibuf, 0, 0 - 5), 1, "negative → 1 digit (treated as 0)");
    assert_eq(load8(&ibuf), 0x30, "negative written as ASCII '0'");
    # Single digit
    assert_eq(tty_itoa(&ibuf, 0, 7), 1, "7 → 1 digit");
    assert_eq(load8(&ibuf), 0x37, "7 written as ASCII '7'");
    # Two digits
    assert_eq(tty_itoa(&ibuf, 0, 42), 2, "42 → 2 digits");
    assert_eq(load8(&ibuf + 0), 0x34, "42 first digit '4'");
    assert_eq(load8(&ibuf + 1), 0x32, "42 second digit '2'");
    # Three digits
    assert_eq(tty_itoa(&ibuf, 0, 123), 3, "123 → 3 digits");
    assert_eq(load8(&ibuf + 0), 0x31, "123 first '1'");
    assert_eq(load8(&ibuf + 1), 0x32, "123 second '2'");
    assert_eq(load8(&ibuf + 2), 0x33, "123 third '3'");
    # Position offset — write at non-zero pos doesn't clobber prior bytes.
    store8(&ibuf + 0, 0x58);   # 'X'
    assert_eq(tty_itoa(&ibuf, 1, 99), 2, "99 at pos 1 → 2 digits");
    assert_eq(load8(&ibuf + 0), 0x58, "byte at pos 0 untouched");
    assert_eq(load8(&ibuf + 1), 0x39, "99 first '9' at pos 1");
    assert_eq(load8(&ibuf + 2), 0x39, "99 second '9' at pos 2");

    # ----- v0.3.0 — signal-mask constants ----------------------------
    # Verify the published TTY_SIGMASK_* values match Linux sigset_t
    # encoding: bit (signum - 1) per signal in the mask. Callers
    # depend on these being correct sums; a typo would silently route
    # the wrong signals to the signalfd.
    test_group("termios.cyr — TTY_SIGMASK_* values");
    # SIGHUP=1 → bit 0, SIGINT=2 → bit 1, SIGTERM=15 → bit 14.
    assert_eq(TTY_SIGMASK_EXIT, 0x4003, "EXIT mask = HUP|INT|TERM");
    # SIGWINCH=28 → bit 27.
    assert_eq(TTY_SIGMASK_WINCH, 0x08000000, "WINCH mask = SIGWINCH(28)");
    # The two masks must be disjoint — caller can OR them safely.
    assert_eq(TTY_SIGMASK_EXIT & TTY_SIGMASK_WINCH, 0, "EXIT and WINCH disjoint");

    # ----- v0.3.0 — TIOCGWINSZ const ---------------------------------
    # The ioctl number is set in stone by the kernel ABI; verify we
    # haven't accidentally bumped it.
    test_group("termios.cyr — TIOCGWINSZ");
    assert_eq(TIOCGWINSZ, 0x5413, "TIOCGWINSZ kernel ABI value");

    # ----- v0.4.0 — tty_sgr bounds check -----------------------------
    # tty_sgr accepts a 1–3 digit SGR parameter [0, 999]. Anything
    # outside that range is rejected with -1 *before* any bytes reach
    # fd 1, so a malformed CSI sequence can't leak to the terminal.
    # Valid codes can't be unit-tested here without redirecting stdout
    # (they write the escape and return 0); rejection paths short-
    # circuit before the write and are safe to call in-test.
    test_group("ansi.cyr — tty_sgr bounds");
    assert_eq(tty_sgr(0 - 1),   0 - 1, "negative code rejected");
    assert_eq(tty_sgr(1000),    0 - 1, "code >= 1000 rejected");
    assert_eq(tty_sgr(0 - 999), 0 - 1, "deeply-negative code rejected");

    # ----- v0.5.1 — truecolor SGR helpers ----------------------------
    # The _buf variants are pure functions over a caller buffer — no
    # fd 1 touch, fully unit-testable. Asserts exact escape bytes for
    # known RGB triples covering 1/2/3-digit channel encodings, plus
    # the per-channel bounds rejection (negative / >255).

    test_group("ansi.cyr — _ansi_emit_u8 digit encoding");
    var dbuf[8];
    var di = 0;
    while (di < 8) { store8(&dbuf + di, 0); di = di + 1; }
    assert_eq(_ansi_emit_u8(&dbuf, 0, 0),   1, "0 → 1 digit");
    assert_eq(load8(&dbuf + 0), 0x30, "0 written as '0'");
    assert_eq(_ansi_emit_u8(&dbuf, 0, 5),   1, "5 → 1 digit");
    assert_eq(load8(&dbuf + 0), 0x35, "5 written as '5'");
    assert_eq(_ansi_emit_u8(&dbuf, 0, 42),  2, "42 → 2 digits");
    assert_eq(load8(&dbuf + 0), 0x34, "42 first '4'");
    assert_eq(load8(&dbuf + 1), 0x32, "42 second '2'");
    assert_eq(_ansi_emit_u8(&dbuf, 0, 255), 3, "255 → 3 digits");
    assert_eq(load8(&dbuf + 0), 0x32, "255 first '2'");
    assert_eq(load8(&dbuf + 1), 0x35, "255 second '5'");
    assert_eq(load8(&dbuf + 2), 0x35, "255 third '5'");

    test_group("ansi.cyr — tty_fg_rgb_buf exact bytes");
    var fbufx[32];
    var fxi = 0;
    while (fxi < 32) { store8(&fbufx + fxi, 0); fxi = fxi + 1; }
    # (255, 0, 128) — max + min + 3-digit, exercises all three branches
    # in _ansi_emit_u8 and confirms the framing bytes are intact.
    var fpos = tty_fg_rgb_buf(&fbufx, 0, 255, 0, 128);
    # ESC[ (2) + "38;2;" (5) + "255" (3) + ";" (1) + "0" (1) + ";" (1) +
    # "128" (3) + "m" (1) = 17 bytes total; fpos is the next free slot.
    assert_eq(fpos, 17, "fg(255,0,128) → 17 bytes (ESC[38;2;255;0;128m)");
    assert_eq(load8(&fbufx + 0),  0x1b, "byte 0 = ESC");
    assert_eq(load8(&fbufx + 1),  0x5b, "byte 1 = '['");
    assert_eq(load8(&fbufx + 2),  0x33, "byte 2 = '3' (fg marker high)");
    assert_eq(load8(&fbufx + 3),  0x38, "byte 3 = '8'");
    assert_eq(load8(&fbufx + 4),  0x3b, "byte 4 = ';'");
    assert_eq(load8(&fbufx + 5),  0x32, "byte 5 = '2' (truecolor marker)");
    assert_eq(load8(&fbufx + 6),  0x3b, "byte 6 = ';'");
    assert_eq(load8(&fbufx + 7),  0x32, "R byte 0 = '2'");
    assert_eq(load8(&fbufx + 8),  0x35, "R byte 1 = '5'");
    assert_eq(load8(&fbufx + 9),  0x35, "R byte 2 = '5'");
    assert_eq(load8(&fbufx + 10), 0x3b, "sep after R");
    assert_eq(load8(&fbufx + 11), 0x30, "G = '0' (single digit)");
    assert_eq(load8(&fbufx + 12), 0x3b, "sep after G");
    assert_eq(load8(&fbufx + 13), 0x31, "B byte 0 = '1'");
    assert_eq(load8(&fbufx + 14), 0x32, "B byte 1 = '2'");
    assert_eq(load8(&fbufx + 15), 0x38, "B byte 2 = '8'");
    assert_eq(load8(&fbufx + 16), 0x6d, "byte 16 = 'm' (terminator)");

    test_group("ansi.cyr — tty_bg_rgb_buf marker swap");
    var gbufx[32];
    var gxi = 0;
    while (gxi < 32) { store8(&gbufx + gxi, 0); gxi = gxi + 1; }
    # (1, 22, 200) — covers 1/2/3-digit on bg path.
    var gpos = tty_bg_rgb_buf(&gbufx, 0, 1, 22, 200);
    # ESC[ (2) + "48;2;" (5) + "1" (1) + ";" (1) + "22" (2) + ";" (1) +
    # "200" (3) + "m" (1) = 16 bytes total.
    assert_eq(gpos, 16, "bg(1,22,200) → 16 bytes");
    assert_eq(load8(&gbufx + 2), 0x34, "byte 2 = '4' (bg marker high)");
    assert_eq(load8(&gbufx + 3), 0x38, "byte 3 = '8'");
    assert_eq(load8(&gbufx + 5), 0x32, "byte 5 = '2' (truecolor marker)");

    test_group("ansi.cyr — tty_fg_rgb_buf bounds rejection");
    var rbufx[32];
    var rxi = 0;
    while (rxi < 32) { store8(&rbufx + rxi, 0); rxi = rxi + 1; }
    assert_eq(tty_fg_rgb_buf(&rbufx, 0, 0 - 1, 0,   0),   0 - 1, "R<0 rejected");
    assert_eq(tty_fg_rgb_buf(&rbufx, 0, 256,   0,   0),   0 - 1, "R>255 rejected");
    assert_eq(tty_fg_rgb_buf(&rbufx, 0, 0,     0 - 1, 0), 0 - 1, "G<0 rejected");
    assert_eq(tty_fg_rgb_buf(&rbufx, 0, 0,     256,   0), 0 - 1, "G>255 rejected");
    assert_eq(tty_fg_rgb_buf(&rbufx, 0, 0,     0,     0 - 1), 0 - 1, "B<0 rejected");
    assert_eq(tty_fg_rgb_buf(&rbufx, 0, 0,     0,     256),   0 - 1, "B>255 rejected");
    # Rejection must not have touched the buffer (first byte stays 0).
    assert_eq(load8(&rbufx + 0), 0, "buf untouched on rejection");
    # Same rejection on bg path.
    assert_eq(tty_bg_rgb_buf(&rbufx, 0, 300, 0, 0), 0 - 1, "bg R>255 rejected");
    assert_eq(load8(&rbufx + 0), 0, "bg: buf untouched on rejection");
    # Direct (fd-writing) variants also reject:
    assert_eq(tty_fg_rgb(0 - 1, 0, 0), 0 - 1, "tty_fg_rgb rejects negative R");
    assert_eq(tty_bg_rgb(0, 0, 999),   0 - 1, "tty_bg_rgb rejects B>255");

    test_group("ansi.cyr — tty_sgr_reset_buf exact bytes");
    var rsbuf[8];
    var rsi = 0;
    while (rsi < 8) { store8(&rsbuf + rsi, 0); rsi = rsi + 1; }
    var rspos = tty_sgr_reset_buf(&rsbuf, 0);
    assert_eq(rspos, 4, "reset_buf → 4 bytes");
    assert_eq(load8(&rsbuf + 0), 0x1b, "reset byte 0 = ESC");
    assert_eq(load8(&rsbuf + 1), 0x5b, "reset byte 1 = '['");
    assert_eq(load8(&rsbuf + 2), 0x30, "reset byte 2 = '0'");
    assert_eq(load8(&rsbuf + 3), 0x6d, "reset byte 3 = 'm'");
    # Position offset — write at non-zero pos doesn't clobber prior bytes.
    store8(&rsbuf + 0, 0x58);   # 'X'
    var rspos2 = tty_sgr_reset_buf(&rsbuf, 1);
    assert_eq(rspos2, 5, "reset_buf at pos 1 → pos 5");
    assert_eq(load8(&rsbuf + 0), 0x58, "byte 0 untouched");
    assert_eq(load8(&rsbuf + 1), 0x1b, "ESC written at pos 1");

    # ----- v0.5.0 — live-fd coverage (skip-when-not-a-TTY) -----------
    # The v0.3.0 syscall-touching surface (`tty_winsize`,
    # `tty_open_signalfd`) had no in-repo coverage at v0.4.x — only
    # the kernel-ABI constants were asserted. These tests exercise
    # the syscalls themselves *when* the host has the right context,
    # and skip cleanly when it doesn't (CI workers without a
    # controlling TTY, seccomp sandboxes, etc.). The success path is
    # informative; the skip path is silent — neither produces a
    # spurious failure on a machine that can't run the assertion.

    # tty_winsize against fd 0. If stdin is a TTY (interactive shell,
    # `cyrius test` invoked from a terminal) tty_winsize returns 0
    # and writes plausible (>0) dimensions. If stdin is piped or
    # redirected (CI, `cyrius test < /dev/null`, etc.) it returns -1
    # and we skip the assertions without faking a pass.
    test_group("termios.cyr — tty_winsize (live)");
    var ws_rows = 0;
    var ws_cols = 0;
    var ws_rc = tty_winsize(0, &ws_rows, &ws_cols);
    if (ws_rc == 0) {
        assert(ws_rows > 0, "live TTY: rows > 0");
        assert(ws_cols > 0, "live TTY: cols > 0");
    }
    # else: stdin is not a TTY in this run — covered by the kernel-ABI
    # const assertion above (TIOCGWINSZ = 0x5413) plus consumer-side
    # PTY smoke. No assertion here to keep the suite green in CI.

    # tty_open_signalfd with the WINCH mask. WINCH was chosen over
    # EXIT to avoid blocking SIGINT/SIGTERM on the test process: if
    # the test hangs for any reason, a developer's ctrl-C still
    # delivers. Blocking SIGWINCH for the duration of the test
    # process is harmless — we're not running a render loop.
    # The signalfd is closed after assertion; the WINCH-block in
    # this thread's signal mask persists until process exit (the
    # test binary exits via syscall(60) right after assert_summary).
    test_group("termios.cyr — tty_open_signalfd (live)");
    var sfd = tty_open_signalfd(TTY_SIGMASK_WINCH);
    if (sfd >= 0) {
        assert(sfd >= 0, "signalfd opened (fd ≥ 0)");
        # SYS_CLOSE = 3 on Linux x86_64. Don't leak the fd into the
        # remainder of the suite or into assert_summary's syscalls.
        syscall(3, sfd);
    }
    # else: signalfd syscall blocked by sandbox / seccomp / very old
    # kernel. Skip silently — consumer integration (chakshu's M2
    # signalfd-driven exit + SIGWINCH loop) covers the live path.

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
